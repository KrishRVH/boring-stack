# Normalize text files to LF by default. Override only where a platform format is
# required for execution.
* text=auto eol=lf

# Shell and platform scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source
*.go text diff=go
*.templ text
*.js text
*.css text

# Build/config
*.dockerignore text
*.env.example text
*.gitignore text
*.gitattributes text
*.json text
*.lock text
*.mod text
*.sum text
*.toml text
*.yaml text
*.yml text
Dockerfile text
go.mod text
go.sum text

# Docs/data
*.csv text
*.md text diff=markdown
*.sql text
*.txt text

# Binary assets/artifacts
*.avif binary
*.db binary
*.gif binary
*.gz binary
*.ico binary
*.jpeg binary
*.jpg binary
*.mp3 binary
*.mp4 binary
*.otf binary
*.pdf binary
*.png binary
*.sqlite binary
*.sqlite3 binary
*.tar binary
*.tgz binary
*.ttf binary
*.wasm binary
*.webp binary
*.woff binary
*.woff2 binary
*.xz binary
*.zip binary
