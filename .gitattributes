# Normalize text files to LF by default. Override only where a platform format is
# required for execution.
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Source
*.go text diff=go
*.templ text
*.js text
*.css text

# Build/config
*.dockerignore text
*.env.example text
*.gitignore text
*.gitattributes text
*.json text
*.lock text
*.mod text
*.sum text
*.toml text
*.yaml text
*.yml text
Dockerfile text
go.mod text
go.sum text

# Docs/data
*.csv text
*.md text diff=markdown
*.sql text
*.txt text
